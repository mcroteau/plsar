<auth:authenticated>
    Hello <auth:user/>!
    You are authenticated.
</auth:authenticated>

<auth:guest>
    <form action="/signin" method="post">
        <input type="text" name="user"/>
        <input type="text" name="pass"/>
        <input type="submit" name="Signin!"/>
    </form>
    <p>Super User<br/>
        username : super<br/>
        password : quietstorm
    </p>
    <p>Basic User<br/>
        username : basic<br/>
        password : quietstorm
    </p>
</auth:guest>